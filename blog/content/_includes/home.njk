---
layout: base.njk
---
{{ content | safe }}

<h2>Topics</h2>
{%- if collections.topics | length %}
<p class="topics-index">{% for t in collections.topics %}<a href="/topics/{{ t.name | slugify }}/">{{ t.name }}</a>{% if not loop.last %}, {% endif %}{% endfor %}</p>
{%- endif %}

<hr>

<h2>Writing</h2>

<ul class="post-list">
{%- for post in collections.posts | reverse %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate }}</time>
  </li>
{%- endfor %}
</ul>
