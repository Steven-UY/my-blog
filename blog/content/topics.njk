---
pagination:
  data: collections.topics
  size: 1
  alias: topic
permalink: "/topics/{{ topic.name | slugify }}/"
eleventyComputed:
  title: "Writing/{{ topic.name }}"
layout: base.njk
---
<h1 class="crumbs"><a href="/">Writing</a> / {{ topic.name }}</h1>

<ul class="post-list">
{%- for post in topic.posts | reverse %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate }}</time>
  </li>
{%- endfor %}
</ul>
